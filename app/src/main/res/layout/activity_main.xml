<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#020617"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="TCL Remote"
            android:textColor="#F8FAFC"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="Not connected"
            android:textColor="#94A3B8"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="vertical"
            android:background="#0F172A"
            android:padding="16dp">

            <EditText
                android:id="@+id/hostInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="TV IP address"
                android:inputType="textUri"
                android:textColor="#F8FAFC"
                android:textColorHint="#64748B" />

            <Button
                android:id="@+id/startPairingButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Start pairing" />

            <EditText
                android:id="@+id/pairingCodeInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Code shown on TV"
                android:inputType="text"
                android:textColor="#F8FAFC"
                android:textColorHint="#64748B" />

            <Button
                android:id="@+id/finishPairingButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Finish pairing" />

            <Button
                android:id="@+id/connectButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Connect remote" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:gravity="center"
            android:orientation="horizontal">

            <Button
                android:id="@+id/backButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Back" />

            <Button
                android:id="@+id/homeButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:text="Home" />

            <Button
                android:id="@+id/powerButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:text="Power" />
        </LinearLayout>

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:columnCount="3"
            android:gravity="center"
            android:useDefaultMargins="true">

            <Space
                android:layout_width="72dp"
                android:layout_height="72dp" />

            <Button
                android:id="@+id/upButton"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:text="▲" />

            <Space
                android:layout_width="72dp"
                android:layout_height="72dp" />

            <Button
                android:id="@+id/leftButton"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:text="◀" />

            <Button
                android:id="@+id/selectButton"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:text="OK" />

            <Button
                android:id="@+id/rightButton"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:text="▶" />

            <Space
                android:layout_width="72dp"
                android:layout_height="72dp" />

            <Button
                android:id="@+id/downButton"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:text="▼" />

            <Space
                android:layout_width="72dp"
                android:layout_height="72dp" />
        </GridLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <Button
                    android:id="@+id/volumeUpButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Vol +" />

                <Button
                    android:id="@+id/volumeDownButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Vol -" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <Button
                    android:id="@+id/channelUpButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Ch +" />

                <Button
                    android:id="@+id/channelDownButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Ch -" />
            </LinearLayout>
        </LinearLayout>

        <EditText
            android:id="@+id/textInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:hint="Keyboard text coming next"
            android:textColor="#F8FAFC"
            android:textColorHint="#64748B" />

        <Button
            android:id="@+id/sendTextButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Send keyboard text" />
    </LinearLayout>
</ScrollView>
